##Growth Model##

#Cellular automaton
The tooth surface is represented as a 2D grid.
Each grid cell stores bacterial density from 0 to 1.

#Nutrient gradient model
create_nutrient_grid() creates more nutrients near the center of the tooth surface.
This makes bacterial growth spatially uneven, like a simulated nutrient-rich region.

#Multi-species biofilm simulation
The model simulates three species at the same time.
Each species has its own growth rate, attachment probability, and initial cell number.

#Probabilistic spreading
If nearby cells already contain bacteria, empty cells may become colonized.
This is controlled by attachment_prob, neighboring bacteria, nutrients, and competition.

#Nutrient-dependent growth
Bacteria grow faster where nutrient levels are higher.
Growth slows down when nutrients are depleted.

#Competition effect
The code calculates total bacteria in a cell.
If a cell is already crowded, growth is reduced.

#Time-step simulation
The model runs for 100 steps.
Each step updates bacterial density and nutrient level.

import numpy as np
import pandas as pd
import matplotlib.pyplot as plt
import matplotlib.animation as animation
from matplotlib.colors import LinearSegmentedColormap
import os

OUTPUT_DIR = "biofilm_output"
os.makedirs(OUTPUT_DIR, exist_ok=True)

SPECIES_PARAMS = {
    "Streptococcus_mitis": {
        "growth_rate": 0.16,
        "attachment_prob": 0.35,
        "initial_cells": 18
    },
    "Veillonella_parvula": {
        "growth_rate": 0.10,
        "attachment_prob": 0.25,
        "initial_cells": 10
    },
    "Porphyromonas_gingivalis": {
        "growth_rate": 0.06,
        "attachment_prob": 0.15,
        "initial_cells": 6
    }
}


def create_nutrient_grid(grid_size):
    """
    Creates more nutrients near the center of the tooth surface.
    """
    x = np.linspace(-1, 1, grid_size)
    y = np.linspace(-1, 1, grid_size)
    X, Y = np.meshgrid(x, y)

    nutrients = np.exp(-(X**2 + Y**2) * 2)
    nutrients = nutrients / nutrients.max()

    return nutrients


def simulate_multispecies_biofilm(
        grid_size=50,
        n_steps=100,
        species_params=SPECIES_PARAMS,
        nutrient_consumption=0.01
):
    """
    Multi-species biofilm simulation.

    Algorithms used:
    1. Cellular automaton
    2. Probabilistic neighbor spreading
    3. Nutrient-dependent growth
    4. Multi-species competition
    """

    species_names = list(species_params.keys())
    n_species = len(species_names)

    grids = np.zeros((n_species, grid_size, grid_size))
    nutrients = create_nutrient_grid(grid_size)

    for s, species in enumerate(species_names):
        initial_cells = species_params[species]["initial_cells"]

        for _ in range(initial_cells):
            x, y = np.random.randint(1, grid_size - 1, 2)
            grids[s, x, y] = 0.5

    snapshots = [grids.copy()]
    nutrient_snapshots = [nutrients.copy()]

    for step in range(n_steps):
        new_grids = grids.copy()
        new_nutrients = nutrients.copy()

        for s, species in enumerate(species_names):
            growth_rate = species_params[species]["growth_rate"]
            attachment_prob = species_params[species]["attachment_prob"]

            for i in range(1, grid_size - 1):
                for j in range(1, grid_size - 1):

                    current_density = grids[s, i, j]

                    neighbors = (
                        grids[s, i - 1, j] +
                        grids[s, i + 1, j] +
                        grids[s, i, j - 1] +
                        grids[s, i, j + 1]
                    )

                    total_bacteria_here = grids[:, i, j].sum()

                    if current_density > 0:
                        nutrient_effect = nutrients[i, j]

                        competition_effect = max(0, 1 - total_bacteria_here)

                        growth = (
                            growth_rate *
                            nutrient_effect *
                            competition_effect *
                            (1 - current_density)
                        )

                        new_grids[s, i, j] = min(1.0, current_density + growth)

                        new_nutrients[i, j] = max(
                            0,
                            new_nutrients[i, j] - nutrient_consumption * current_density
                        )

                    elif neighbors > 0:
                        nutrient_effect = nutrients[i, j]
                        competition_effect = max(0, 1 - total_bacteria_here)

                        spread_chance = (
                            attachment_prob *
                            neighbors *
                            nutrient_effect *
                            competition_effect
                        )

                        if np.random.random() < spread_chance:
                            new_grids[s, i, j] = 0.1

        grids = new_grids
        nutrients = new_nutrients

        snapshots.append(grids.copy())
        nutrient_snapshots.append(nutrients.copy())

    return np.array(snapshots), np.array(nutrient_snapshots), species_names


print("Running upgraded multi-species biofilm simulation...")

