# Based top 3 species
SPECIES = [
    "Streptococcus_mitis",
    "Veillonella_parvula",
    "Porphyromonas_gingivalis"
]

# Different movement speeds per species
# S. mitis — fast early colonizer
# Veillonella — medium, follows Streptococcus
# P. gingivalis — slow, disease-associated late colonizer
SPEEDS = [0.08, 0.05, 0.02]
COLORS = ["blue", "green", "red"]

N_BACTERIA = 30    # bacteria per species
N_STEPS    = 150   # simulation time steps


def simulate_movement(n_bacteria, n_steps, speed, diffusion=0.02):
    """
    Simulates bacterial random walk with chemotaxis
    toward a nutrient source (sugar on tooth surface)
    """
    # Start bacteria scattered randomly in oral space
    positions = np.random.uniform(-1, 1, (n_bacteria, 3))
    positions[:, 2] *= 0.1   # flatten z = tooth surface

    # Nutrient source — sugar on tooth surface center
    nutrient = np.array([0.0, 0.0, 0.0])

    all_positions = [positions.copy()]

    for step in range(n_steps):
        # Random Brownian motion
        random_move = np.random.normal(0, diffusion, (n_bacteria, 3))

        # Chemotaxis — bacteria sense and move toward nutrient
        direction = nutrient - positions
        distance  = np.linalg.norm(direction, axis=1, keepdims=True)
        direction = direction / (distance + 1e-8)

        # Update positions
        positions = positions + (speed * direction) + random_move

        # Keep within oral cavity bounds
        positions = np.clip(positions, -1, 1)

        all_positions.append(positions.copy())

    return np.array(all_positions)  # shape: (n_steps, n_bacteria, 3)


# SIMULATION
print("Running movement simulation...")

all_trajectories = {}
for name, speed in zip(SPECIES, SPEEDS):
    print(f"  Simulating {name} at speed {speed}...")
    traj = simulate_movement(N_BACTERIA, N_STEPS, speed)
    all_trajectories[name] = traj

    # Save flat CSV for Blender
    flat = traj.reshape(traj.shape[0], -1)
    pd.DataFrame(flat).to_csv(
        DATA_PATH + f"trajectory_{name}.csv",
        index=False, header=False
    )

print("\nAll trajectories saved!")


# PLOT FINAL POSITIONS
fig = plt.figure(figsize=(12, 8))
