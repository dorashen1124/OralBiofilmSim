#Competition Model 

import numpy as np
import pandas as pd
from scipy.integrate import odeint
import matplotlib.pyplot as plt

# Load data
DATA_PATH = "/Users/dslol/"
abundance = pd.read_csv(DATA_PATH + "oral_abundance.csv", index_col=0)

# Use real average abundances as starting populations
initial_populations = abundance.mean(axis=1).values[:5]
species_names = [name.replace("species:", "")
                 for name in abundance.index.tolist()[:5]]

print("Starting populations:")
for name, pop in zip(species_names, initial_populations):
    print(f"  {name}: {pop:.4f}")

# Define Lotka-Volterra competition model
def lotka_volterra(N, t, r, A):
    N = np.maximum(N, 0)   # prevent negative populations
    dNdt = N * (r + A @ N)
    return dNdt

# Parameters
n_species = len(initial_populations)
r = np.array([0.8, 0.6, 0.5, 0.7, 0.4])    # growth rates
A = np.full((n_species, n_species), -0.01)   # competition
np.fill_diagonal(A, -0.05)                   # self-limitation

# Time points — 200 steps simulating bacterial growth
t = np.linspace(0, 200, 1000)

# Solve ODE
solution = odeint(lotka_volterra, initial_populations, t, args=(r, A))

# Save trajectory for Blender later
trajectory_df = pd.DataFrame(solution, columns=species_names)
trajectory_df.to_csv(DATA_PATH + "population_trajectory.csv")
print("\nTrajectory saved!")

# Plot population over time
plt.figure(figsize=(12, 6))
for i, name in enumerate(species_names):
    plt.plot(t, solution[:, i], label=name, linewidth=2)

plt.xlabel("Time")
plt.ylabel("Relative abundance")
plt.title("Simulated oral bacterial population dynamics")
plt.legend(loc="upper right", fontsize=9)
plt.tight_layout()
plt.savefig(DATA_PATH + "population_dynamics.png")
plt.show()
print("Plot saved!")

