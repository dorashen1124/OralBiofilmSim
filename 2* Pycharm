for name, color in zip(SPECIES, COLORS):
    traj = all_trajectories[name]

    # Plot final position of each bacterium
    final_positions = traj[-1]
    ax.scatter(
        final_positions[:, 0],
        final_positions[:, 1],
        final_positions[:, 2],
        c=color, label=name.replace("_", " "),
        s=50, alpha=0.8
    )

    # Plot movement trail of first 3 bacteria
    for b in range(3):
        ax.plot(
            traj[:, b, 0],
            traj[:, b, 1],
            traj[:, b, 2],
            c=color, alpha=0.3, linewidth=0.8
        )

ax.set_xlabel("X")
ax.set_ylabel("Y")
ax.set_zlabel("Z (depth)")
ax.set_title("Oral bacterial movement toward nutrient source")
ax.legend(loc="upper left", fontsize=9)

plt.tight_layout()
plt.savefig(DATA_PATH + "bacterial_movement.png")
plt.show()
print("Movement plot saved!")


# PRINT SUMMARY
print("\n── Simulation Summary ──────────────────")
for name in SPECIES:
    traj  = all_trajectories[name]
    start = traj[0].mean(axis=0)
