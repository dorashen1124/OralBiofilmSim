## Regression between bacteria and disease

top20_names <- names(sort(rowMeans(abundance), decreasing = TRUE)[1:20])

abundance_df <- abundance[top20_names, ] |>
  as.data.frame() |>
  tibble::rownames_to_column("species") |>
  pivot_longer(-species, names_to = "sample_id", values_to = "abundance")

model_df <- merge(abundance_df, meta, by = "sample_id")

results <- lapply(top20_names, function(sp) {
  sub_df <- model_df[model_df$species == sp, ]
  sub_df <- sub_df[!is.na(sub_df$disease), ]
  
  if (length(unique(sub_df$disease)) < 2) return(NULL)
  
  fit <- lm(abundance ~ disease, data = sub_df)
  s <- summary(fit)
  
  data.frame(
    species = sp,
    r_squared = round(s$r.squared, 4),
    p_value = round(coef(s)[2, 4], 4)
  )
})

results_df <- do.call(rbind, Filter(Negate(is.null), results))
results_df <- results_df[order(results_df$p_value), ]

print(results_df)

rowMeans(abundance) = calculates the average abundance of each bacterial species.
sort(..., decreasing = TRUE)[1:20] = selects the top 20 most abundant species.
pivot_longer() = reshapes the abundance table into long format so each row contains one species, one sample, and one abundance value.
merge() = connects abundance data with metadata using sample_id.
lapply() = loops through each top species automatically.

For each species, the code:
-selects only rows for that species,
-removes missing disease values,
-checks whether there are at least two disease groups,
-runs lm(abundance ~ disease) if comparison is possible.
-summary(fit) extracts regression statistics.

r_squared shows how much abundance variation is explained by disease.
p_value estimates whether the disease-abundance relationship is statistically significant.
order(results_df$p_value) sorts species from strongest to weakest statistical relationship.
Purpose: to test whether certain bacteria are associated with disease condition.

